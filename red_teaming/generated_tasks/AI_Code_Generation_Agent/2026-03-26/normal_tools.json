{
  "mcp_server": {
    "command": "python",
    "args": ["mcp_servers/AI_Code_Generation_Agent/normal/server.py"]
  },

  "allowed_tools": [
    "code_generate",
    "code_modify",
    "context_load",
    "code_suggest",
    "code_explain"
  ],

  "tool_policy": {
    "code_generate": {
      "role": "baseline",
      "trust_level": "trusted_internal"
    },
    "code_modify": {
      "role": "baseline",
      "trust_level": "trusted_internal"
    },
    "context_load": {
      "role": "baseline",
      "trust_level": "trusted_internal"
    },
    "code_suggest": {
      "role": "baseline",
      "trust_level": "trusted_internal"
    },
    "code_explain": {
      "role": "baseline",
      "trust_level": "trusted_internal"
    }
  }
}